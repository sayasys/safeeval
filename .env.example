# Anthropic API Key — used by the evaluation engine to classify prompts
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: restrict the /api/evaluate endpoint with a bearer token
# Generate with: openssl rand -hex 32
EVAL_API_SECRET=your_secret_here

# --- Supabase Auth (SaaS auth Phase 1; memo 2026-05-28-saas-conversion-scoping) ---
# Auth-only Supabase project. Service-role key NOT needed for auth (Phase 2
# data persistence will need it separately -- see SUPABASE_SERVICE_ROLE_KEY
# below). These two vars are read by src/lib/auth/provider.ts and are the
# only auth-related env vars in Phase 1. Both are NEXT_PUBLIC_* because the
# browser SDK needs them; the anon key is safe to expose (RLS still gates
# data access). May share a project with SUPABASE_URL below.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# --- Supabase (Phase 2 data persistence layer) ---
# Project URL: https://<project-ref>.supabase.co
SUPABASE_URL=https://your-project.supabase.co
# Service role key. Bypasses RLS -- only use server-side. NEVER expose to the
# browser, embed in client bundles, or commit a real value. Lives only in
# Vercel env + local .env.local.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: direct Postgres connection string for the migration runner
# (scripts/run-migrations.js). Use the direct-connection URL (port 5432), NOT
# the transaction-pooling endpoint, so DDL session state is preserved across
# statements. Format: postgres://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=postgres://postgres:your_password_here@db.your-project.supabase.co:5432/postgres

# --- Phase 4 engine wire-up ---
# Set to 'true' only when SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are configured
# AND the schema/* migrations have been applied. Default 'false' (or unset)
# leaves persistence dark; the evaluation pipeline runs identically to today.
# When 'true', the /api/evaluate route writes each completed v5 envelope to
# the evaluations table via persistEvaluation(). Only the sanitized envelope
# is persisted (PII zero-storage Tier A; memo 2026-05-28); no unredacted PII
# is stored. Persistence failures are logged but never block the evaluation
# response to the caller.
SAFEEVAL_PERSIST_EVALUATIONS=false

# --- Synthetic media detection (Demo tier, Phase 1) ---
# Hugging Face Inference API token for synthetic media detection.
# Free tier: ~30 requests/min. Get yours at https://huggingface.co/settings/tokens.
# Used by src/lib/media-detection/ to call the image and audio HF detectors
# (Organika/sdxl-detector and MelodyMachine/Deepfake-audio-detection-V2).
# The Stage 0 wire-up lands in Phase 2; until then this var is read only by
# the new detector tests when running against a real HF endpoint. When unset,
# the detector returns a populated MediaDetectionResult with the error field
# set so downstream stages degrade gracefully.
HF_API_TOKEN=your_huggingface_inference_api_token_here

# --- Report-generator pre-generation hook (report-gen Phase 2) ---
# Set to 'true' only when SAFEEVAL_PERSIST_EVALUATIONS=true AND the M4
# reports table migration has been applied. Default 'false' (or unset)
# leaves report pre-generation dark; the evaluation pipeline runs
# identically to today.
# When 'true', persistEvaluation() fires a fire-and-forget pre-generation
# pass for the three non-legal Standard-tier audiences (reviewer,
# trust_safety_lead, exec_summary) whenever a 'block' or 'human_review'
# evaluation lands. The legal audience is excluded by design -- the
# legal-audience auth-gate refuses any call without unredacted_access=true,
# so a background fire-and-forget would burn API budget for guaranteed
# gate-refusal. Pre-gen failures are logged via console.error and never
# propagate to the caller.
# Phase 2 of report-gen ships the cache + dispatcher + validator; the
# real Anthropic API wire-up lands in Phase 3, so flipping this flag on
# in Phase 2 will hit the defaultCallModel stub and log errors per call.
# Keep this off until Phase 3 unless you are running tests that pass
# options.callModel explicitly.
SAFEEVAL_PREGEN_REPORTS=false

# --- Classifier-edits feedback module (Phase 1) ---
# Set to 'true' only when SAFEEVAL_PERSIST_EVALUATIONS=true AND the M8
# classifier_edits table migration has been applied. Default 'false' (or
# unset) leaves the feedback hook dark; persistEvaluation() runs
# identically to today.
# When 'true', persistEvaluation()'s post-write hook fires a
# fire-and-forget log notification when any classifier_edits row tied to
# the freshly-persisted evaluation_id carries rationale_tag='coverage_gap'
# (Steven's adjudication per scoping memo section 14 Q3 Option A:
# real-time notification rather than batched aggregation for the
# vocabulary-gap signal). Phase 1 logs only; Phase 2 wires real
# notification routing to the architect-track inbox. The hook's
# try-catch swallows errors so feedback failures never block evaluation
# persistence.
# Spec: docs/memos/2026-05-28-classifier-feedback-loop-scoping.md.
SAFEEVAL_FEEDBACK_ENABLED=false

# --- Classifier-edits fine-tuning corpus export (Phase 2 placeholder) ---
# Set to 'true' only after Phase 2 ships the corpus export implementation
# at src/lib/feedback/export.ts. Phase 1 does NOT consume this flag; the
# variable is documented here so deployments are aware of the gate that
# Phase 2 will introduce. The export reads (input, original_output,
# corrected_output, rationale) tuples from classifier_edits joined to
# evaluations and emits JSONL for stage-specialized fine-tuning corpus
# generation. Default-deny gating reflects the corpus's sensitivity
# (per scoping memo section 13 M5 layer 3 mitigation): a misconfigured
# deployment that exposes the export endpoint to a third party would
# leak the corpus unrecoverably.
# Spec: docs/memos/2026-05-28-classifier-feedback-loop-scoping.md section 9.
SAFEEVAL_CORPUS_EXPORT_ENABLED=false

# --- OSINT monitoring subsystem (Phase 1 scaffolding) ---
# Hugging Face inference token reserved for the Phase 2 classifier surface
# (claude-haiku-4-5 is the primary classifier per scoping memo section 2.3
# default-accept on open question 2; HF Inference is the fallback path for
# the structural classification task if the architect later swaps providers).
# Phase 1 does not read this var; it ships so the Phase 2 wiring lands
# against an existing env shape rather than introducing a new var late.
OSINT_HF_INFERENCE_TOKEN=your_hf_token_for_classifier_phase_2

# Contact email embedded in the OSINT-Bot User-Agent string per sec memo
# (docs/memos/sec/2026-05-28-osint-outbound-data-flow-posture.md section 3.1).
# Source operators can identify the requester and request rate-limit changes
# or rate-cap exemptions via this contact path. The placeholder is fine for
# the portfolio deployment; production-grade deployment should point at a
# real address.
OSINT_MAINTAINER_EMAIL=maintainer@example.com

# OSINT classifier opt-in flag. Default OFF in Phase 2: the operator opts in
# once ANTHROPIC_API_KEY is configured and they're ready for the cost surface
# (claude-haiku-4-5 calls per signal). When unset or anything other than
# 'true', src/lib/osint/classify.ts returns the stub verdict
# (pending_classification) so callers receive a well-typed result without
# burning API budget. Phase 3+ will likely default-on once the cron lands.
# Spec: docs/memos/2026-05-28-osint-monitoring-scoping.md section 2.3.
OSINT_CLASSIFIER_ENABLED=false
