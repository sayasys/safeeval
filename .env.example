# Anthropic API Key — used by the evaluation engine to classify prompts
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: restrict the /api/evaluate endpoint with a bearer token
# Generate with: openssl rand -hex 32
EVAL_API_SECRET=your_secret_here

# --- Supabase (Phase 2 data persistence layer) ---
# Project URL: https://<project-ref>.supabase.co
SUPABASE_URL=https://your-project.supabase.co
# Service role key. Bypasses RLS -- only use server-side. NEVER expose to the
# browser, embed in client bundles, or commit a real value. Lives only in
# Vercel env + local .env.local.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: direct Postgres connection string for the migration runner
# (scripts/run-migrations.js). Use the direct-connection URL (port 5432), NOT
# the transaction-pooling endpoint, so DDL session state is preserved across
# statements. Format: postgres://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=postgres://postgres:your_password_here@db.your-project.supabase.co:5432/postgres

# --- Phase 4 engine wire-up ---
# Set to 'true' only when SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are configured
# AND the schema/* migrations have been applied. Default 'false' (or unset)
# leaves persistence dark; the evaluation pipeline runs identically to today.
# When 'true', the /api/evaluate route writes each completed v5 envelope to
# the evaluations table via persistEvaluation(). KMS is stubbed in Phase 2/4
# (Phase 3 deferred), so the ciphertext columns persist as null until the
# real KMS module lands. Persistence failures are logged but never block the
# evaluation response to the caller.
SAFEEVAL_PERSIST_EVALUATIONS=false
